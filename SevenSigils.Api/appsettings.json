{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      }
    ]
  },
  "Jwt": {
    "Key": "CHANGE_ME_WITH_A_LONGER_SECRET_KEY_32+",
    "Issuer": "SevenSigils",
    "Audience": "SevenSigils",
    "ExpiryMinutes": 60
  },
  "Cors": {
    "FrontendOrigin": "http://localhost:5173"
  },
  "BlazonData": {
    "JsonPath": "data/blazonDb.json"
  },
  "MongoDb": {
    "ConnectionString": "mongodb://localhost:27017",
    "DatabaseName": "sevensigils",
    "BlazonCollection": "blazons",
    "UserCollection": "users",
    "SeedOnStartup": true
  },
  "AllowedHosts": "*"
}
