# Normalisation des fins de ligne
* text=auto

# Forcer LF pour les fichiers texte
*.cs text eol=lf
*.csproj text eol=lf
*.slnx text eol=lf
*.json text eol=lf
*.md text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.css text eol=lf
*.html text eol=lf
*.svg text eol=lf

# Fichiers binaires — pas de conversion
*.png binary
*.jpg binary
*.jpeg binary
*.webp binary
*.ico binary
